# Copy this file to .env and fill in your token from @BotFather.
TELEGRAM_BOT_TOKEN=PUT_YOUR_TOKEN_HERE

# (Optional) LibreTranslate-compatible endpoint for live chat translation.
# Free public instances: https://libretranslate.com/, https://translate.terraprint.co/
# When unset, chat translation is disabled and the bot relays messages as-is.
# TRANSLATION_API_URL=https://libretranslate.com/translate
# TRANSLATION_API_KEY=your_key_if_required
